{
    "name": "purewater-dashboard",
    "version": "1.0.0",
    "description": "基于 Next.js + Electron 的纯水制备优化装置仿真监控模型",
    "main": "electron/main.js",
    "scripts": {
        "dev": "next dev -p 3000",
        "dev:web": "next dev -p 3000",
        "dev:electron": "concurrently \"npm:dev:web\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
        "dev:electron:linux": "concurrently \"npm:dev:web\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron . --no-sandbox\"",
        "build:web": "next build",
        "build": "npm run build:web",
        "start": "next start -p 3000",
        "start:electron": "cross-env NODE_ENV=production electron .",
        "dist:win": "npm run build:web && electron-builder --win nsis"
    },
    "author": "",
    "license": "MIT",
    "dependencies": {
        "echarts": "^5.5.0",
        "next": "^14.2.31",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "cross-env": "^7.0.3",
        "electron": "^28.2.3",
        "electron-builder": "^24.13.3",
        "wait-on": "^8.0.5"
    },
    "build": {
        "appId": "com.purewater.dashboard",
        "productName": "PureWater Dashboard",
        "files": [
            "electron/**/*",
            "out/**/*",
            "package.json"
        ],
        "directories": {
            "output": "release"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "win": {
            "signAndEditExecutable": false,
            "target": [
                "nsis"
            ]
        }
    }
}